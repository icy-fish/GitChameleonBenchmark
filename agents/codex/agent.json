{
  "default_model": "gpt-5-codex",
  "workspace_dir": ".",
  "use_stdin_prompt": true,
  "result_file_template": "sample_{example_id}.py",
  "command": [
    "bash",
    "-lc",
    "source \"$HOME/.nvm/nvm.sh\" >/dev/null 2>&1 || true; codex exec --json --skip-git-repo-check --full-auto -C {workspace} -m {model} --add-dir {workspace} -"
  ]
}
